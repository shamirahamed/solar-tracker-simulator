{
  "name": "Solar Tracker Simulator",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "postCreateCommand": "pip install -r backend/requirements.txt",

  "forwardPorts": [8000, 5500],
  "portsAttributes": {
    "8000": {
      "label": "Backend API",
      "onAutoForward": "silent"
    },
    "5500": {
      "label": "Frontend",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ritwickdey.LiveServer"
      ],
      "settings": {
        "liveServer.settings.port": 5500,
        "liveServer.settings.root": "/frontend",
        "liveServer.settings.open": false
      }
    }
  }
}
